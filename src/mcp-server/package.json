{
  "name": "trinity-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for orchestrating Trinity agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector http://localhost:8080/mcp",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "keywords": [
    "mcp",
    "trinity",
    "agent",
    "orchestration"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "fastmcp": "^4.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "hono": ">=4.12.18",
    "axios": ">=1.15.2",
    "fast-uri": ">=3.1.2",
    "@hono/node-server": ">=1.19.13",
    "ip-address": ">=10.2.0"
  }
}
